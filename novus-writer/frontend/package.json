{
  "name": "novus-writer",
  "version": "0.1.0",
  "description": "A modern, offline-first desktop notes application inspired by Microsoft Word",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@lexical/react": "^0.12.5",
    "@lexical/rich-text": "^0.12.5",
    "@lexical/table": "^0.12.5",
    "@lexical/list": "^0.12.5",
    "@lexical/link": "^0.12.5",
    "@lexical/code": "^0.12.5",
    "@lexical/hashtag": "^0.12.5",
    "@lexical/markdown": "^0.12.5",
    "@lexical/history": "^0.12.5",
    "@lexical/selection": "^0.12.5",
    "@lexical/utils": "^0.12.5",
    "@lexical/html": "^0.12.5",
    "lexical": "^0.12.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "@tanstack/react-virtual": "^3.0.1",
    "uuid": "^9.0.1",
    "date-fns": "^3.2.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.1",
    "@vitest/ui": "^1.2.1",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.3.0",
    "jsdom": "^24.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
